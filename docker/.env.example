TZ=Asia/Shanghai

NAPCAT_UID=1000
NAPCAT_GID=1000
NAPCAT_ACCOUNT=
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest
NAPCAT_WS_HOST_PORT=10300
NAPCAT_WEB_HOST_PORT=10301
NAPCAT_WEBUI_TOKEN=change_me
NAPCAT_WS_URL=ws://napcat:3001
NAPCAT_ACCESS_TOKEN=
NAPCAT_MEDIA_SEND_MODE=base64
NAPCAT_MEDIA_TEMP_DIR=

AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=30000

QWEATHER_API_HOST=https://devapi.qweather.com
QWEATHER_API_KEY=
QWEATHER_LANG=zh

ADMIN_PASSWORD=change_me
ADMIN_PORT=3100
ADMIN_WEB_ORIGIN=http://127.0.0.1:10303
ADMIN_WEB_HOST_PORT=10303
ADMIN_SESSION_TTL_SECONDS=43200

TASK_CENTER_POLL_MS=15000
MAX_CONTEXT_MESSAGES=20
LOG_LEVEL=info

# DS2API 默认固定版本，配合 Renovate 自动开 PR 升级。
# 如果要让 Watchtower 无人值守拉取新版，把它改成 ghcr.io/cjackhwang/ds2api:latest，
# 然后用 docker compose --profile auto-update up -d 启动。
DS2API_IMAGE=ghcr.io/cjackhwang/ds2api:v3.6.1
DS2API_HOST_PORT=10302
DS2API_ADMIN_KEY=ds2api
DS2API_CONFIG_PATH=/app/config.json
DS2API_LOG_LEVEL=INFO

WATCHTOWER_POLL_INTERVAL_SECONDS=86400
