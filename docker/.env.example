TZ=Asia/Shanghai
NAPCAT_UID=1000
NAPCAT_GID=1000
NAPCAT_ACCOUNT=
NAPCAT_WS_URL=ws://napcat:3001
NAPCAT_ACCESS_TOKEN=
NAPCAT_MEDIA_SEND_MODE=base64
# 当后续 bot 也进 Docker 时，可把 bot 与 NapCat 共同挂载到同一个目录，例如 /shared-media
NAPCAT_MEDIA_TEMP_DIR=
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
TASK_CENTER_POLL_MS=15000
MAX_CONTEXT_MESSAGES=20
LOG_LEVEL=info
