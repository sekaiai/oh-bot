NAPCAT_WS_URL=ws://127.0.0.1:3001
NAPCAT_ACCESS_TOKEN=
NAPCAT_MEDIA_SEND_MODE=base64
# 当 NAPCAT_MEDIA_SEND_MODE=local_path 或 file_url 时，建议配置为和 NapCat 共用的挂载目录
NAPCAT_MEDIA_TEMP_DIR=
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=30000
# 以上 AI 配置会作为后台“运行设置”的默认值
QWEATHER_API_HOST=https://devapi.qweather.com
QWEATHER_API_KEY=
QWEATHER_LANG=zh
ADMIN_PASSWORD=change_me
ADMIN_PORT=3100
ADMIN_WEB_ORIGIN=http://127.0.0.1:5173
ADMIN_SESSION_TTL_SECONDS=43200
MAX_CONTEXT_MESSAGES=20
LOG_LEVEL=info
